# ── Lifted Sign — configuration ─────────────────────────────────────────────
# Copy to .env and fill in. Only SIGN_SECRET is strictly required.
#   cp .env.example .env

# ── Required ────────────────────────────────────────────────────────────────
# All sessions, signer-access cookies, and one-time codes are keyed off this.
# Generate a real one — the server refuses to boot with a placeholder:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SIGN_SECRET=

# ── Core ────────────────────────────────────────────────────────────────────
# External URL of this install. Used to build signer links + email content AND to
# fill the marketing landing's canonical/OpenGraph/Twitter URLs and hero mockup —
# set it to your real public URL (e.g. https://sign.yourco.com) before going live.
# NOTE: session cookies use the __Host- prefix, which browsers accept ONLY over HTTPS
# (localhost is exempt). Behind a plain-http LAN IP or bare domain the login cookie is
# dropped — put Lifted Sign behind a TLS-terminating proxy for any non-localhost host.
PUBLIC_BASE_URL=http://localhost:8080
PORT=8080

# Where the SQLite database and sealed PDFs live (created on boot).
SIGN_DATA_DIR=./data

# Optional: use Postgres instead of the default SQLite. Leave blank for SQLite.
# DATABASE_URL=postgresql://user:pass@localhost:5432/liftedsign

# ── Email ───────────────────────────────────────────────────────────────────
# With SMTP_HOST blank, invites/reminders/OTPs print to the console (dev only).
# Set these for real delivery:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_STARTTLS=true
# MAIL_FROM=sign@example.com
MAIL_FROM_NAME=Lifted Sign
# MAIL_REPLY_TO=

# ── Legal identity (disclosures, certificate, email footer) ─────────────────
# Blank by default. Fill in YOUR entity — do not ship someone else's.
LEGAL_ENTITY=
LEGAL_ADDRESS=
SUPPORT_EMAIL=

# ── Public-page identity (marketing landing head, footer, hero mockup) ───────
# Shown in <meta>/OpenGraph, the footer, and the "your-domain" hero pill. Both
# default to sensible values (operator name → LEGAL_ENTITY or MAIL_FROM_NAME;
# operator URL → PUBLIC_BASE_URL), so a fresh build never ships a placeholder.
# OPERATOR_NAME=Your Company, LLC
# OPERATOR_URL=https://yourco.com

# ── PAdES signing material (optional, but unlocks CERTIFIED validation) ──────
# With a cert+key set, executed PDFs carry a real PKCS#7/PAdES certification
# signature that PDF readers can validate (and, with a CA-issued or trusted cert,
# show as a trusted signature). WITHOUT them, documents still get a tamper-evident
# AES-256 integrity seal — legally valid, just not a PAdES certificate signature,
# so Adobe/readers show "signature validity unknown" rather than a green check.
# Provision a self-signed pair with:  python -m sign.pdf_sign provision --out ./secrets
# SIGN_PADES_CERT_PATH=./secrets/signing-cert.pem
# SIGN_PADES_KEY_PATH=./secrets/signing-key.pem
# SIGN_PADES_KEY_PASSPHRASE=

# ── Optional sign-in add-ons ────────────────────────────────────────────────
# Passwordless email MAGIC-LINK sign-in is always on and needs no config — with
# SMTP unset the link prints to the console (dev). Google and phone are OPTIONAL
# extra methods; unset groups are simply hidden on the sign-in page.
# Google login:
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT=
# Phone OTP + SMS 2FA (Twilio Verify):
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_VERIFY_SERVICE_SID=

# ── Deployment mode ─────────────────────────────────────────────────────────
# true = anyone may self-register (create an account on first sign-in). Set false for
# a PRIVATE install: no new accounts are created by any method (magic-link, Google, or
# phone) — only accounts that already exist can sign in.
SIGN_SIGNUPS_OPEN=true
# Comma-separated emails that may reach the operator console:
# ADMIN_EMAILS=you@example.com

# ── Hosted tier only (Stripe billing; ignored when SIGN_HOSTED_MODE=false) ──
SIGN_HOSTED_MODE=false
# SIGN_PLAN_FREE_MONTHLY_LIMIT=3
# STRIPE_SECRET_KEY=
# STRIPE_PRICE_ID=
# STRIPE_WEBHOOK_SECRET=
